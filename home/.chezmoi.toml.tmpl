{{- $osid := .chezmoi.os -}}
{{- if hasKey .chezmoi.osRelease "id" -}}
{{-   $osid = printf "%s-%s" .chezmoi.os .chezmoi.osRelease.id -}}
{{- end -}}

{{- $hostProfiles := dict
  "void" (list "workstation" "laptop" "development" "owned")
  "beastbox" (list "workstation" "development" "gaming" "server" "owned")
-}}

{{- $roleProfiles := list "workstation" "headless" -}}
{{- $capabilityProfiles := list "development" "gaming" "server" "laptop" "owned" -}}
{{- $profileChoices := concat $roleProfiles $capabilityProfiles -}}
{{- $defaultProfiles := get $hostProfiles .chezmoi.hostname | default (list "workstation" "development") -}}
{{- $profiles := $defaultProfiles -}}
{{- $profilesFromEnv := false -}}

{{- if env "DOTFILES_PROFILES" -}}
{{-   $profiles = splitList "," (env "DOTFILES_PROFILES") -}}
{{-   $profilesFromEnv = true -}}
{{- else -}}
{{-   $profiles = promptMultichoiceOnce . "profiles" "profiles" $profileChoices $defaultProfiles -}}
{{- end -}}

{{- range $profile := $profiles -}}
{{-   if not (has $profile $profileChoices) -}}
{{-     fail (printf "unknown dotfiles profile %q; valid profiles: %s" $profile (join ", " $profileChoices)) -}}
{{-   end -}}
{{- end -}}

{{- if ne (len $profiles) (len (uniq $profiles)) -}}
{{-   fail "dotfiles profiles must not contain duplicates" -}}
{{- end -}}

{{- $workstation := has "workstation" $profiles -}}
{{- $headless := has "headless" $profiles -}}
{{- if eq $workstation $headless -}}
{{-   fail "select exactly one machine role: workstation or headless" -}}
{{- end -}}

{{- $gitName := promptStringOnce . "git.name" "git user name" "Thomas Kristensen" -}}
{{- $gitEmail := promptStringOnce . "git.email" "git user email" "" -}}

encryption = "age"
sourceDir = {{ .chezmoi.workingTree | quote }}

[age]
    identity = "~/.config/chezmoi/key.txt"
    recipient = ""

[data]
    os = {{ .chezmoi.os | quote }}
    osid = {{ $osid | quote }}
    hostname = {{ .chezmoi.hostname | quote }}
    machine = {{ promptStringOnce . "machine" "machine name" .chezmoi.hostname | quote }}
    profiles = {{ $profiles | toToml }}

[data.git]
    name = {{ $gitName | quote }}
    email = {{ $gitEmail | quote }}
