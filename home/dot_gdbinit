set confirm off
set pagination off

set print pretty on
set print object on
set print static-members on
set print vtbl on
set print demangle on

set demangle-style auto
set disassemble-next-line on
set disassembly-flavor intel

set history save on
set history size 10000
set history filename ~/.cache/gdb/history

python
try:
    gdb.execute("set debuginfod enabled on")
except gdb.error:
    pass
end

define btfull
    thread apply all bt full
end

define regs
    info registers
end

define libs
    info sharedlibrary
end

define maps
    info proc mappings
end

define cls
    shell clear
end

define hook-quit
    set confirm off
end

document btfull
Show full backtraces for all threads.
end

document regs
Show registers.
end

document libs
Show loaded shared libraries.
end

document maps
Show process memory mappings.
end

document cls
Clear the terminal.
end

# GDB dashboard
source ~/.local/share/gdb-dashboard/dashboard.gdb

# The normal terminal should remain usable even when GDB is started outside
# the tmux dashboard launcher.
dashboard -layout source assembly registers stack threads expressions memory

dashboard source -style height 15
dashboard assembly -style height 15
