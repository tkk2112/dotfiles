{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Neovim project settings",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "global"
  ],
  "properties": {
    "global": {
      "$ref": "#/$defs/settings"
    },
    "languages": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/settings"
      }
    },
    "files": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          {
            "type": "string",
            "minLength": 1
          },
          {
            "$ref": "#/$defs/fileSettings"
          }
        ]
      }
    },
    "commands": {
      "$ref": "#/$defs/commands"
    }
  },
  "$defs": {
    "optionValue": {
      "oneOf": [
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "type": [
              "boolean",
              "number",
              "string"
            ]
          }
        }
      ]
    },
    "vimSettings": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "opt": {
          "type": "object",
          "propertyNames": {
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "additionalProperties": {
            "$ref": "#/$defs/optionValue"
          }
        }
      }
    },
    "settings": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "vim": {
          "$ref": "#/$defs/vimSettings"
        },
        "save_on_focus": {
          "type": "boolean"
        },
        "format_on_save": {
          "type": "boolean"
        }
      }
    },
    "fileSettings": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "filetype": {
          "type": "string",
          "minLength": 1
        },
        "vim": {
          "$ref": "#/$defs/vimSettings"
        },
        "save_on_focus": {
          "type": "boolean"
        },
        "format_on_save": {
          "type": "boolean"
        }
      }
    },
    "environment": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "additionalProperties": {
        "type": "string"
      }
    },
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command"
      ],
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "output": {
          "type": "string",
          "enum": [
            "terminal",
            "quickfix"
          ]
        },
        "cwd": {
          "type": "string",
          "minLength": 1,
          "description": "Absolute path or project-relative path. Supports ${projectRoot} and ${env:NAME}."
        },
        "env": {
          "$ref": "#/$defs/environment",
          "description": "Per-command environment overrides. Values support ${projectRoot}, ${cwd}, and ${env:NAME}."
        },
        "compiler": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+$"
        },
        "open": {
          "type": "string",
          "enum": [
            "always",
            "errors",
            "never"
          ]
        }
      }
    },
    "commands": {
      "type": "object",
      "propertyNames": {
        "pattern": "^.$"
      },
      "additionalProperties": {
        "oneOf": [
          {
            "type": "string",
            "minLength": 1
          },
          {
            "$ref": "#/$defs/command"
          }
        ]
      }
    }
  }
}
