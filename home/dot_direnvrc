select_python() {
  local python_executable=${1:-python}
  local python_path
  local python_version

  unset PYTHONHOME

  python_path=$(uv python find "$python_executable") || return 1
  if [[ -z $python_path ]]; then
    log_error "Could not find Python executable: $python_executable"
    return 1
  fi

  python_version=$("$python_path" -V 2>&1 | cut -d' ' -f 2 | cut -d . -f 1-2)

  if [[ -z $python_version ]]; then
    log_error "Could not determine the Python version at: $python_path"
    return 1
  fi

  printf 'Using Python %s at %s\n' "$python_version" "$python_path"
  export SELECTED_PYTHON_PATH="$python_path"
}

create_and_activate_venv() {
  uv venv 2>/dev/null || return 1

  if [[ ! -f .venv/bin/activate ]]; then
    log_error "Virtual environment activation script not found"
    return 1
  fi

  # shellcheck source=/dev/null
  source .venv/bin/activate
}

setup_environment() {
  source_up_if_exists
  dotenv_if_exists
  source_env_if_exists .envrc.local

  if [[ -f pyproject.toml ]]; then
    uv sync
  fi
}

# Usage: uv_python_setup [python executable]
uv_python_setup() {
  local desired_python=${1:-python}

  select_python "$desired_python" || return 1
  create_and_activate_venv || return 1
  setup_environment
}
