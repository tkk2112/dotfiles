#!/bin/sh
set -eu

{{- $profiles := .profiles | default (list) -}}
{{- $packages := .packages | default (dict) -}}
{{- $uvTools := get $packages "uv_tools" | default (list) -}}

{{ define "uvToolLines" }}
{{- $profiles := index . 0 -}}
{{- $tools := index . 1 | default (list) -}}
{{- $os := index . 2 -}}

{{- range $tool := $tools -}}
{{- $name := get $tool "name" -}}
{{- $group := get $tool "group" | default "core" -}}
{{- $package := get $tool "package" | default $name -}}
{{- $command := get $tool "command" | default $name -}}
{{- $with := get $tool "with" | default (list) -}}
{{- $skip := get $tool "skip" | default (list) -}}

{{- $enabledGroup := or (eq $group "core") (has $group $profiles) -}}
{{- $enabledOS := not (has $os $skip) -}}

{{- if and $name $enabledGroup $enabledOS -}}
{{ printf "%s|%s" $package $command }}
{{- range $dependency := $with -}}
{{ printf "|%s" $dependency }}
{{- end }}
{{ printf "\n" }}
{{- end -}}
{{- end -}}
{{ end }}

UV_TOOLS="$(cat <<'EOF'
{{ template "uvToolLines" (list $profiles $uvTools .chezmoi.os) }}
EOF
)"

if [ "${DOTFILES_SKIP_UV_TOOLS:-}" = "1" ]; then
    printf 'Skipping uv tools because DOTFILES_SKIP_UV_TOOLS=1\n'
    exit 0
fi


if ! printf '%s\n' "$UV_TOOLS" | awk 'NF { found = 1 } END { exit !found }'; then
    printf '%s\n' 'No uv tools selected for this platform'
    exit 0
fi

PATH="$HOME/.local/bin:$PATH"
export PATH

if ! command -v uv >/dev/null 2>&1; then
    printf 'uv is not installed; skipping uv tools\n'
    exit 0
fi

run() {
    printf '+ %s\n' "$*"

    if [ "${DOTFILES_UV_TOOLS_DRY_RUN:-}" = "1" ]; then
        return 0
    fi

    "$@"
}

printf '%s\n' "$UV_TOOLS" | awk 'NF' | while IFS='|' read -r package command with1 with2 with3 with4 with5; do
    if command -v "$command" >/dev/null 2>&1; then
        printf 'uv tool already available: %s\n' "$command"
        continue
    fi

    set -- uv tool install "$package"

    for dep in "$with1" "$with2" "$with3" "$with4" "$with5"; do
        if [ -n "$dep" ]; then
            set -- "$@" --with "$dep"
        fi
    done

    run "$@"
done
