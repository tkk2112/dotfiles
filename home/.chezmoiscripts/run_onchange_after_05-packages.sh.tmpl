#!/bin/sh
set -eu

{{ $profiles := .profiles | default (list) }}
{{ $owned := has "owned" $profiles }}
{{ define "packageLines" }}
{{- $manager := index . 0 -}}
{{- $profiles := index . 1 -}}
{{- $catalog := index . 2 -}}
{{- $defaultManagers := list "brew" "apt" "dnf" "pacman" -}}
{{- range $pkg := $catalog -}}
{{- $name := get $pkg "name" -}}
{{- $group := get $pkg "group" | default "core" -}}
{{- $managers := get $pkg "managers" | default $defaultManagers -}}
{{- $names := get $pkg "names" | default (dict) -}}
{{- $enabledGroup := or (eq $group "core") (has $group $profiles) -}}
{{- $enabledManager := has $manager $managers -}}
{{- if and $name $enabledGroup $enabledManager -}}
{{- $packageName := get $names $manager | default $name -}}
{{- printf "%s\n" $packageName -}}
{{- end -}}
{{- end -}}
{{ end }}

{{ define "caskLines" }}
{{- $profiles := index . 0 -}}
{{- $casks := index . 1 | default (list) -}}
{{- range $cask := $casks -}}
{{- $name := get $cask "name" -}}
{{- $group := get $cask "group" | default "core" -}}
{{- $tap := get $cask "tap" | default "" -}}
{{- $caskName := get $cask "cask" | default $name -}}
{{- $enabledGroup := or (eq $group "core") (has $group $profiles) -}}
{{- if and $name $enabledGroup -}}
{{- if $tap -}}
{{- printf "%s/%s\n" $tap $caskName -}}
{{- else -}}
{{- printf "%s\n" $caskName -}}
{{- end -}}
{{- end -}}
{{- end -}}
{{ end }}

PROFILE_OWNED="{{ if $owned }}true{{ else }}false{{ end }}"

BREW_PACKAGES="$(cat <<'EOF'
{{ template "packageLines" (list "brew" $profiles .packages.catalog) }}
EOF
)"

BREW_CASKS="$(cat <<'EOF'
{{ template "caskLines" (list $profiles .packages.casks) }}
EOF
)"

APT_PACKAGES="$(cat <<'EOF'
{{ template "packageLines" (list "apt" $profiles .packages.catalog) }}
EOF
)"

APT_PPAS="$(cat <<'EOF'
{{- range (.packages.apt.ppas | default (list)) }}
{{ . }}
{{- end }}
EOF
)"

DNF_PACKAGES="$(cat <<'EOF'
{{ template "packageLines" (list "dnf" $profiles .packages.catalog) }}
EOF
)"

PACMAN_PACKAGES="$(cat <<'EOF'
{{ template "packageLines" (list "pacman" $profiles .packages.catalog) }}
EOF
)"

if [ "${DOTFILES_SKIP_PACKAGES:-}" = "1" ]; then
    printf 'Skipping package install because DOTFILES_SKIP_PACKAGES=1\n'
    exit 0
fi

run() {
    printf '+ %s\n' "$*"

    if [ "${DOTFILES_PACKAGES_DRY_RUN:-}" = "1" ]; then
        return 0
    fi

    "$@"
}

run_as_root() {
    if [ "$(id -u)" -eq 0 ]; then
        run "$@"
    elif command -v sudo >/dev/null 2>&1; then
        run sudo "$@"
    else
        printf 'Need root or sudo to install packages\n' >&2
        exit 1
    fi
}

normalize_packages() {
    printf '%s\n' "$1" | awk 'NF && !seen[$0]++ { print }'
}

print_packages() {
    label="$1"
    packages="$2"

    printf 'Installing %s packages:\n' "$label"
    printf '%s\n' "$packages" | sed 's/^/  - /'
}

install_user_packages() {
    label="$1"
    package_block="$2"
    shift 2

    packages="$(normalize_packages "$package_block")"

    if [ -z "$packages" ]; then
        printf 'No %s packages selected\n' "$label"
        return 0
    fi

    print_packages "$label" "$packages"

    # shellcheck disable=SC2086
    run "$@" $packages
}

install_root_packages() {
    label="$1"
    package_block="$2"
    shift 2

    packages="$(normalize_packages "$package_block")"

    if [ -z "$packages" ]; then
        printf 'No %s packages selected\n' "$label"
        return 0
    fi

    print_packages "$label" "$packages"

    # shellcheck disable=SC2086
    run_as_root "$@" $packages
}

install_brew_casks() {
    casks="$(normalize_packages "$BREW_CASKS")"

    if [ -z "$casks" ]; then
        printf 'No Homebrew casks selected\n'
        return 0
    fi

    print_packages "Homebrew cask" "$casks"

    # shellcheck disable=SC2086
    run brew install --cask $casks
}

install_brew() {
    if ! command -v brew >/dev/null 2>&1; then
        printf 'Homebrew is not installed; skipping packages\n' >&2
        exit 0
    fi

    install_user_packages Homebrew "$BREW_PACKAGES" brew install
    install_brew_casks
}

install_apt_ppas() {
    ppas="$(normalize_packages "$APT_PPAS")"

    if [ -z "$ppas" ]; then
        printf 'No apt PPAs configured\n'
        return 0
    fi

    if [ ! -r /etc/os-release ]; then
        printf 'Cannot determine Linux distribution; skipping apt PPAs\n' >&2
        return 0
    fi

    # shellcheck disable=SC1091
    . /etc/os-release

    # Launchpad PPAs are Ubuntu-specific. Do not attempt to add them on Debian
    # or another distribution that happens to use apt.
    if [ "${ID:-}" != "ubuntu" ]; then
        printf 'Skipping Ubuntu PPAs on distribution: %s\n' "${ID:-unknown}"
        return 0
    fi

    install_root_packages apt-bootstrap \
        "software-properties-common" \
        env DEBIAN_FRONTEND=noninteractive \
        apt-get install -y --no-install-recommends

    print_packages "Ubuntu PPA" "$ppas"

    while IFS= read -r ppa; do
        [ -n "$ppa" ] || continue
        run_as_root add-apt-repository -y "$ppa"
    done <<EOF
$ppas
EOF

    # Refresh metadata after adding the repositories.
    run_as_root apt-get update
}

install_apt() {
    if [ "$PROFILE_OWNED" != "true" ] && [ "${DOTFILES_CI:-}" != "true" ]; then
        printf 'Skipping apt packages because owned profile is not enabled\n'
        return 0
    fi

    # Initial metadata is needed to install software-properties-common.
    run_as_root apt-get update

    # On Ubuntu, add configured PPAs before installing the package catalog.
    install_apt_ppas

    install_root_packages apt "$APT_PACKAGES" \
        env DEBIAN_FRONTEND=noninteractive \
        apt-get install -y --no-install-recommends
}

install_dnf() {
    if [ "$PROFILE_OWNED" != "true" ] && [ "${DOTFILES_CI:-}" != "true" ]; then
        printf 'Skipping dnf packages because owned profile is not enabled\n'
        return 0
    fi

    install_root_packages dnf "$DNF_PACKAGES" dnf install -y
}

install_pacman() {
    if [ "$PROFILE_OWNED" != "true" ] && [ "${DOTFILES_CI:-}" != "true" ]; then
        printf 'Skipping pacman packages because owned profile is not enabled\n'
        return 0
    fi

    install_root_packages pacman "$PACMAN_PACKAGES" pacman -Sy --noconfirm --needed
}

case "{{ .chezmoi.os }}" in
darwin)
    install_brew
    ;;

linux)
    if command -v apt-get >/dev/null 2>&1; then
        install_apt
    elif command -v dnf >/dev/null 2>&1; then
        install_dnf
    elif command -v pacman >/dev/null 2>&1; then
        install_pacman
    else
        printf 'No supported package manager found; skipping packages\n' >&2
    fi
    ;;

*)
    printf 'Unsupported OS for package install: %s\n' "{{ .chezmoi.os }}" >&2
    ;;
esac
