export DISABLE_UPDATE_PROMPT=true
ZSH_CUSTOM_AUTOUPDATE_QUIET=true
ZSH_CUSTOM_AUTOUPDATE_NUM_WORKERS=8

export ZSH="$HOME/.oh-my-zsh"
export ZSH_CACHE_DIR="$HOME/.cache/oh-my-zsh"

if [[ -n ${SSH_CONNECTION:-} ]]; then
  zstyle :omz:plugins:ssh-agent agent-forwarding yes
fi
zstyle :omz:plugins:ssh-agent lazy yes
zstyle :omz:plugins:ssh-agent quiet yes

if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

typeset -U path cdpath fpath manpath

brew_bin=""

for candidate in \
  /opt/homebrew/bin/brew \
  /usr/local/bin/brew \
  /home/linuxbrew/.linuxbrew/bin/brew \
  "$HOME/.linuxbrew/bin/brew"
do
  if [[ -x "$candidate" ]]; then
    brew_bin="$candidate"
    break
  fi
done

if [[ -n "$brew_bin" ]]; then
  eval "$("$brew_bin" shellenv)"

  brew_prefix="$(brew --prefix)"

  for completion_dir in \
    "$brew_prefix/share/zsh/functions" \
    "$brew_prefix/share/zsh/site-functions"
  do
    if [[ -d "$completion_dir" ]]; then
      fpath=("$completion_dir" $fpath)
    fi
  done
fi

fpath=(
  "$HOME/.zsh/completions"
  $fpath
)
unset brew_bin brew_prefix candidate completion_dir

plugins=(
  aliases
  autoupdate
  branch
  chezmoi
  colored-man-pages
  command-not-found
  direnv
  fzf
  nmap
  rsync
  ssh-agent
  sudo
  uv
  zsh-autosuggestions
  zsh-completions
  zsh-syntax-highlighting
)

if darwin; then
  plugins+=(brew macos)
fi

ZSH_THEME="powerlevel10k/powerlevel10k"
source "$ZSH/oh-my-zsh.sh"

source ~/.zsh/options.zsh
source ~/.zsh/history.zsh
source ~/.zsh/keybindings.zsh
source ~/.zsh/aliases.zsh
source ~/.zsh/dirs.zsh

for func_file in ~/.zsh/functions/*.zsh; do
  source "$func_file"
done

[[ -r ~/.p10k.zsh ]] && source ~/.p10k.zsh

if [[ -d ~/ProtonDrive/work/zsh ]]; then
  for func_file in ~/ProtonDrive/work/zsh/*.zsh; do
    [[ -f $func_file ]] && source "$func_file"
  done
fi

[[ -r ~/.zshrc_local ]] && source ~/.zshrc_local
